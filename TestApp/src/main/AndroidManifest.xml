<activity
    android:name=".MainActivity"
    android:exported="true"
    android:launchMode="singleTask"
    android:configChanges="orientation|screenSize|keyboardHidden"
    android:label="@string/app_name"
    android:theme="@style/AppTheme.NoActionBar">

    <!-- ================================= -->
    <!-- NORMAL APP LAUNCH -->
    <!-- ================================= -->

    <intent-filter>

        <action
            android:name="android.intent.action.MAIN" />

        <category
            android:name="android.intent.category.LAUNCHER" />

    </intent-filter>

    <!-- ================================= -->
    <!-- SHARE TEXT -->
    <!-- ================================= -->

    <intent-filter>

        <action
            android:name="android.intent.action.SEND" />

        <category
            android:name="android.intent.category.DEFAULT" />

        <data
            android:mimeType="text/plain" />

    </intent-filter>

    <!-- ================================= -->
    <!-- UNIVERSAL STREAM / PLAYER SUPPORT -->
    <!-- ================================= -->

    <intent-filter>

        <action
            android:name="android.intent.action.VIEW" />

        <category
            android:name="android.intent.category.DEFAULT" />

        <category
            android:name="android.intent.category.BROWSABLE" />

        <!-- HTTP / HTTPS -->

        <data
            android:scheme="http" />

        <data
            android:scheme="https" />

        <!-- GENERIC VIDEO -->

        <data
            android:mimeType="video/*" />

        <!-- GENERIC AUDIO -->

        <data
            android:mimeType="audio/*" />

        <!-- MP4 -->

        <data
            android:mimeType="video/mp4" />

        <!-- MPEG -->

        <data
            android:mimeType="video/mpeg" />

        <!-- MPEG TS -->

        <data
            android:mimeType="video/mp2t" />

        <!-- HLS -->

        <data
            android:mimeType="application/x-mpegURL" />

        <!-- APPLE HLS -->

        <data
            android:mimeType="application/vnd.apple.mpegurl" />

        <!-- GENERIC STREAM -->

        <data
            android:mimeType="application/octet-stream" />

    </intent-filter>

    <!-- ================================= -->
    <!-- M3U8 PATH SUPPORT -->
    <!-- ================================= -->

    <intent-filter>

        <action
            android:name="android.intent.action.VIEW" />

        <category
            android:name="android.intent.category.DEFAULT" />

        <category
            android:name="android.intent.category.BROWSABLE" />

        <data
            android:scheme="http"
            android:pathPattern=".*\\.m3u8" />

        <data
            android:scheme="https"
            android:pathPattern=".*\\.m3u8" />

    </intent-filter>

    <!-- ================================= -->
    <!-- MPD DASH SUPPORT -->
    <!-- ================================= -->

    <intent-filter>

        <action
            android:name="android.intent.action.VIEW" />

        <category
            android:name="android.intent.category.DEFAULT" />

        <category
            android:name="android.intent.category.BROWSABLE" />

        <data
            android:scheme="http"
            android:pathPattern=".*\\.mpd" />

        <data
            android:scheme="https"
            android:pathPattern=".*\\.mpd" />

    </intent-filter>

    <!-- ================================= -->
    <!-- TS STREAM SUPPORT -->
    <!-- ================================= -->

    <intent-filter>

        <action
            android:name="android.intent.action.VIEW" />

        <category
            android:name="android.intent.category.DEFAULT" />

        <category
            android:name="android.intent.category.BROWSABLE" />

        <data
            android:scheme="http"
            android:pathPattern=".*\\.ts" />

        <data
            android:scheme="https"
            android:pathPattern=".*\\.ts" />

    </intent-filter>

    <!-- ================================= -->
    <!-- MP4 PATH SUPPORT -->
    <!-- ================================= -->

    <intent-filter>

        <action
            android:name="android.intent.action.VIEW" />

        <category
            android:name="android.intent.category.DEFAULT" />

        <category
            android:name="android.intent.category.BROWSABLE" />

        <data
            android:scheme="http"
            android:pathPattern=".*\\.mp4" />

        <data
            android:scheme="https"
            android:pathPattern=".*\\.mp4" />

    </intent-filter>

</activity>
